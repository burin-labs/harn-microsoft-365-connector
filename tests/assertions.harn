/** Require that a smoke-test condition is true. */
pub fn expect(condition, message = "expectation failed") {
  require condition, message
}

/** Require that two smoke-test values are equal. */
pub fn expect_eq(actual, expected, message = "values differ") {
  require actual == expected,
    message + ": expected " + to_string(expected) + ", got "
    + to_string(
    actual,
  )
}
